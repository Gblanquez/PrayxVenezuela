# Browser-safe key. This can be exposed in Webflow/frontend code.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Server-only key. Never put this in Webflow or client JavaScript.
STRIPE_SECRET_KEY=sk_test_replace_me

# Server-only webhook secret once Stripe webhooks are configured.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public site URL used by the serverless checkout endpoint.
SITE_URL=https://your-site.webflow.io
WEBFLOW_ORIGIN=https://your-site.webflow.io
STRIPE_SUCCESS_URL=https://your-site.webflow.io/donation-success
STRIPE_CANCEL_URL=https://your-site.webflow.io/donate
